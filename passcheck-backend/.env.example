# Server configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Comma-separated list of exact allowed frontend origins.
# Do not use "*" in production.
CORS_ORIGIN=http://localhost:5173

# MongoDB connection string for visitor tracking persistence.
# Paste your own Atlas URI here; do not commit real credentials.
MONGODB_URI=SET_YOUR_OWN_MONGODB_ATLAS_URI

# Optional absolute path to the wordlist directory.
# WORDLIST_PATH=D:\path\to\passcheck-backend\data\wordlists
