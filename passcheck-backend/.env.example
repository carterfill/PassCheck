# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# CORS Configuration
# Use '*' to allow all origins or specify comma-separated list
# Example: https://passcheck.vercel.app,https://www.passcheck.com
CORS_ORIGIN=*

# MongoDB Configuration
# Get free MongoDB Atlas cluster at: https://www.mongodb.com/cloud/atlas/register
# Connection string format: SET_YOUR_OWN_MONGODB_ATLAS_URI
MONGODB_URI=SET_YOUR_OWN_MONGODB_ATLAS_URI

# Optional: Add other configuration here
